# openclaw-pinchbench

FROM ghcr.io/openclaw/openclaw:latest

USER root
# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    git \
    curl \
    vim \
    jq \
    && rm -rf /var/lib/apt/lists/*

USER node
# Install uv (Python package manager used by PinchBench)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/home/node/.local/bin:$PATH"

ARG PINCH_BENCH_VER=1e2ba6b5a3f527dee2f4fab0220c4b9ed429dd00
ARG PINCH_BENCH_REPO="https://github.com/pinchbench/skill.git"
RUN git clone $PINCH_BENCH_REPO && \
    cd skill && \
    git checkout -b test $PINCH_BENCH_VER 

#HEALTHCHECK NONE
#ENTRYPOINT ["/bin/bash", "-c"]
#CMD ["openclaw --version && echo 'Ready for benchmarks'"]
#CMD ["while true; do echo hello; sleep 100; done"]
